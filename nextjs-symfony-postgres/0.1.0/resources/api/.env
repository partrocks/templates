# Baseline .env for the Symfony api.
#
# DATABASE_URL, APP_ENV, APP_NAME, and APP_SECRET are injected at runtime by
# the develop environment (docker) or by the cloud `api-host` slot — never
# commit real values here. This file only holds safe defaults used when the
# runtime does not supply an override.

APP_ENV=prod
APP_DEBUG=0
APP_NAME=partrocks-api
APP_SECRET=change-me-at-runtime

# Fallback DATABASE_URL used when nothing else sets one. The runtime ALWAYS
# overrides this with a real connection string (develop: docker `db`; cloud:
# primary-db slot output).
DATABASE_URL=postgresql://app:app@127.0.0.1:5432/app?serverVersion=16&charset=utf8
